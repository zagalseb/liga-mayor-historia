---
import Base from '../../layouts/Base.astro';
import teams from '../../data/teams.json';
import { allSeasons, seasonSlug } from '../../utils/seasons';

const B = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const withBase = (path: string) => B + (path.startsWith('/') ? path.slice(1) : path);

const teamName = (id: string) =>
  teams.find((t) => t.id === id)?.nombre_corto ?? id;
const teamLogo = (id: string) => {
  const url = teams.find((t) => t.id === id)?.logo_url ?? null;
  return url ? withBase(url) : null;
};

const winnerOf = (g: { home_team_id: string; away_team_id: string; home_score: number; away_score: number } | undefined) =>
  g ? (g.home_score > g.away_score ? g.home_team_id : g.away_team_id) : null;

const seasons = allSeasons.map((s) => {
  let champions: string[] = [];
  const multiFinales = ['final_independencia', 'final_libertad', 'final_revolucion_independencia', 'final_centro', 'final_norte'];
  const hasMulti = s.games.some((g) => multiFinales.includes(g.tipo));
  if (s.divisiones || hasMulti) {
    for (const tipo of multiFinales) {
      const w = winnerOf(s.games.find((g) => g.tipo === tipo));
      if (w) champions.push(w);
    }
  } else {
    const w = winnerOf(s.games.find((g) => g.tipo === 'final'));
    if (w) champions.push(w);
  }
  return { ...s, slug: seasonSlug(s), champions };
});
---

<Base title="Temporadas">
  <h1>Temporadas</h1>

  <ul class="season-list">
    {seasons.map((s) => (
      <li>
        <a href={`${B}temporadas/${s.slug}`}>
          <span class="year">{s.year}</span>
          <span class="meta">{s.liga} · {s.conferencia}</span>
          {s.champions.length > 0 && (
            <span class="champion">
              🏆
              {s.champions.map((c) =>
                teamLogo(c)
                  ? <img src={teamLogo(c)!} alt={teamName(c)} class="champ-logo" />
                  : <span>{teamName(c)}</span>
              )}
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  h1 { margin-bottom: 1.5rem; }

  .season-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .season-list li { border: 1px solid #ddd; border-radius: 6px; background: #fff; }
  .season-list a {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    text-decoration: none;
    color: inherit;
  }
  .season-list a:hover { background: #f5f7ff; }

  .year { font-size: 1.2rem; font-weight: 700; min-width: 3rem; }
  .meta { color: #555; font-size: 0.9rem; flex: 1; }
  .champion { display: flex; align-items: center; gap: 0.35rem; white-space: nowrap; }
  .champ-logo { width: 36px; height: 36px; object-fit: contain; display: block; }
</style>
