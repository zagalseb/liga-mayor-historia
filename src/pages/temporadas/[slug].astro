          <span class="match-lugar">{playoffs.finalCentro.lugar}</span>
        </div>
      </div>
    </>
  )}

  {playoffs.final && (
    <>
      <h3>Final</h3>
      <div class="games-list">
        <div class="match-row playoff-match final-match">
          <a href={`${B}equipos/${playoffs.final.home_team_id}/${slug}`} class={`mn mn-home ${playoffs.final.home_score > playoffs.final.away_score ? 'winner' : ''}`}>{teamName(playoffs.final.home_team_id)}</a>
